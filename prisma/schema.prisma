// prisma/schema.prisma
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String?
  name           String
  role           Role      @default(MEMBER)
  status         UserStatus @default(ACTIVE)
  phone          String?
  avatar         String?
  lastLogin      DateTime?
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  memberDetails  Member?
  accounts       Account[]
  sessions       Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Member {
  id               String   @id @default(cuid())
  userId           String   @unique
  memberId         String   @unique
  dateOfBirth      DateTime?
  address          String?
  city             String?
  state            String?
  occupation       String?
  monthlyIncome    Decimal? @db.Decimal(12, 2)
  emergencyContact String?
  relationship     String?
  joinDate         DateTime @default(now())
  status           MemberStatus @default(ACTIVE)
  
  // Relations
  user             User     @relation(fields: [userId], references: [id])
  savings          Savings[]
  loans            Loan[]
  transactions     Transaction[]
  attendances      Attendance[]  // ✅ ADD THIS - opposite relation for Attendance
  
  @@map("members")
}

model Savings {
  id          String   @id @default(cuid())
  memberId    String
  amount      Decimal  @db.Decimal(12, 2)
  type        SavingsType
  description String?
  date        DateTime @default(now())
  reference   String?
  
  member      Member   @relation(fields: [memberId], references: [id])
  
  @@map("savings")
}

model Loan {
  id              String   @id @default(cuid())
  memberId        String
  amount          Decimal  @db.Decimal(12, 2)
  purpose         String
  interestRate    Decimal  @db.Decimal(5, 2)
  duration        Int      // in months
  status          LoanStatus @default(PENDING)
  appliedDate     DateTime @default(now())
  approvedDate    DateTime?
  disbursedDate   DateTime?
  monthlyPayment  Decimal  @db.Decimal(12, 2)
  remainingBalance Decimal @db.Decimal(12, 2)
  notes           String?
  
  member          Member   @relation(fields: [memberId], references: [id])
  repayments      LoanRepayment[]
  
  @@map("loans")
}

model LoanRepayment {
  id            String   @id @default(cuid())
  loanId        String
  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime @default(now())
  reference     String?
  status        PaymentStatus @default(COMPLETED)
  
  loan          Loan     @relation(fields: [loanId], references: [id])
  
  @@map("loan_repayments")
}

model Transaction {
  id          String   @id @default(cuid())
  memberId    String
  type        TransactionType
  amount      Decimal  @db.Decimal(12, 2)
  description String
  reference   String   @unique
  status      PaymentStatus @default(COMPLETED)
  date        DateTime @default(now())
  
  member      Member   @relation(fields: [memberId], references: [id])
  
  @@map("transactions")
}

model Meeting {
  id           String    @id @default(cuid())
  title        String
  description  String?
  date         DateTime
  venue        String?
  agenda       String?
  minutes      String?
  status       MeetingStatus @default(SCHEDULED)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  attendees    Attendance[]
  
  @@map("meetings")
}

model Attendance {
  id        String   @id @default(cuid())
  meetingId String
  memberId  String
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  
  meeting   Meeting  @relation(fields: [meetingId], references: [id])
  member    Member   @relation(fields: [memberId], references: [id]) // ✅ This now works because Member has attendances[]
  
  @@unique([meetingId, memberId])
  @@map("attendances")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FINANCE_OFFICER
  LOAN_OFFICER
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SavingsType {
  DEPOSIT
  WITHDRAWAL
  INTEREST
  PENALTY
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
  ACTIVE
  COMPLETED
  DEFAULTED
}

enum TransactionType {
  SAVINGS_DEPOSIT
  SAVINGS_WITHDRAWAL
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  INTEREST_PAYMENT
  FEE_PAYMENT
  MEMBERSHIP_FEE
  DIVIDEND_PAYMENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum MeetingStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
  LATE
}